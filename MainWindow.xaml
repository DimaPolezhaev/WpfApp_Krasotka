<Window x:Class="WpfApp_Krasotka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_Krasotka"
        mc:Ignorable="d"
        Title="Салон красоты Красотка" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFF0F8FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF1565C0" Padding="25">
            <TextBlock Text='Салон красоты "Красотка"' 
                      HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" 
                      Foreground="White" TextAlignment="Center"/>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Работа с Базой Данных" FontSize="16" FontWeight="SemiBold" 
                          Foreground="#FF1565C0" Margin="0,0,0,15" 
                          HorizontalAlignment="Center"/>

                <Button x:Name="b_db" Content="Открыть БД" Height="40" 
                        FontSize="14" FontWeight="SemiBold" Background="#FF1976D2" 
                        Foreground="White" Click="b_db_Click" BorderThickness="0" 
                        Cursor="Hand" Margin="0,5" Padding="10,0"/>
            </StackPanel>

            <!-- Правая колонка -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Ежедневные функции" FontSize="16" FontWeight="SemiBold" 
                          Foreground="#FF1565C0" Margin="0,0,0,15" 
                          HorizontalAlignment="Center"/>

                <Button x:Name="b_work" Content="Администратор салона" Height="40" 
                        FontSize="14" FontWeight="SemiBold" Background="#FF1976D2" 
                        Foreground="White" Click="b_work_Click" BorderThickness="0" 
                        Cursor="Hand" Margin="0,5" Padding="10,0"/>
            </StackPanel>
        </Grid>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#FFE3F2FD" Padding="20">
            <Button x:Name="b_exit" Content="Выход" Height="36" Width="120"
                    FontSize="14" FontWeight="SemiBold" Background="#FF78909C" 
                    Foreground="White" Click="b_exit_Click" 
                    HorizontalAlignment="Center" BorderThickness="0" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>