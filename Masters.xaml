<Window x:Class="WpfApp_Krasotka.Masters"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_Krasotka"
        mc:Ignorable="d"
        Title="Управление мастерами" Height="550" Width="1000">

    <Grid Background="#FFF0F8FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <Label x:Name="l_tabM" Content="Мастера" Grid.Row="0" Grid.ColumnSpan="2"
       HorizontalAlignment="Center" VerticalAlignment="Center" 
       Height="45" FontSize="24" FontWeight="Bold" 
       Background="#FF1976D2" Foreground="White" Padding="20,5" 
       Width="150" Margin="0,10,300,10"/>

        <!-- Левая панель: кнопки управления и поиск -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="10,5,10,10">

            <!-- Панель кнопок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="b_masterShowActive" Content="Показать активных" Height="35" Width="160" 
                        FontSize="12" FontWeight="Bold" Click="b_masterShowActive_Click" 
                        Background="#FF2196F3" Foreground="White" Margin="5,0"/>
                <Button x:Name="b_masterShowInactive" Content="Показать неактивных" Height="35" Width="169" 
                        FontSize="12" FontWeight="Bold" Click="b_masterShowInactive_Click" 
                        Background="#FF78909C" Foreground="White" Margin="5,0"/>
                <Button x:Name="b_masterDelete" Content="Удалить" Height="35" Width="112" 
                        FontSize="12" FontWeight="Bold" Background="#5695f6" 
                        Foreground="White" Click="b_masterDelete_Click" Margin="5,0"/>
                <Button x:Name="b_masterAdd" Content="Добавить мастера" Height="35" Width="137" 
                        FontSize="12" FontWeight="Bold" Background="#5695f6" 
                        Foreground="White" Click="b_masterAdd_Click" Margin="5,0"/>
            </StackPanel>

            <!-- Панель поиска -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Поиск мастеров:" VerticalAlignment="Center" Margin="0,0,10,0" 
                          FontSize="14" FontWeight="SemiBold"/>
                <TextBox x:Name="searchTextBox" Width="494" Height="30" Padding="5" 
                        TextChanged="searchTextBox_TextChanged" FontSize="14"
                        VerticalContentAlignment="Center" Background="White"
                        BorderBrush="#FF90CAF9" BorderThickness="1"/>
            </StackPanel>
        </StackPanel>

        <!-- Таблица мастеров -->
        <DataGrid x:Name="masterCell" Grid.Row="2" Grid.Column="0"
          ItemsSource="{Binding MastersClass}" ColumnWidth="*"
          Margin="10,0,10,0" 
          AutoGenerateColumns="False" SelectionMode="Single"
          SelectionChanged="masterCell_SelectionChanged"
          IsReadOnly="True">

            <!-- Полный стиль для синего выделения -->
            <DataGrid.Resources>
                <!-- Синий цвет выделения -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF2196F3"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFBBDEFB"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

                <!-- Стиль для строк -->
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#FF1976D2"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFE3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для ячеек -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#FF1976D2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Код мастера" Binding="{Binding MasterCode}" Width="80"/>
                <DataGridTextColumn Header="Имя мастера" Binding="{Binding MasterName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding MasterTel}" Width="120"/>
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding ServTypeName}" Width="120"/>
                <DataGridTextColumn Header="Активный" Binding="{Binding MasterActivity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель информации о мастере -->
        <Border Grid.RowSpan="3" Grid.Column="1" 
                Background="#FFE3F2FD" Margin="10,10,10,5" 
                BorderBrush="#FF1976D2" BorderThickness="2" 
                CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="Информация о мастере" FontSize="16" FontWeight="Bold" 
                          HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#FF1976D2"/>

                <TextBlock Text="Код мастера:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox x:Name="l_mc" FontSize="14" Height="30" Margin="0,0,0,10" 
                        Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                <TextBlock Text="Имя мастера:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox x:Name="l_mn" FontSize="14" Height="30" Margin="0,0,0,10" 
                        Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                <TextBlock Text="Телефон:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox x:Name="l_mt" FontSize="14" Height="30" Margin="0,0,0,10" 
                        Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                <TextBlock Text="Тип услуги:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <ComboBox x:Name="cb_servType" FontSize="14" Height="30" Margin="0,0,0,10" 
                         Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"
                         DisplayMemberPath="ServType"/>

                <TextBlock Text="Активность:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <ComboBox x:Name="cb_activity" FontSize="14" Height="30" Margin="0,0,0,20" 
                         Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False">
                    <ComboBoxItem Content="Да" IsSelected="True"/>
                    <ComboBoxItem Content="Нет"/>
                </ComboBox>

                <Button x:Name="b_masterChange" Content="✏️ Изменить данные мастера" Height="40" 
                        FontSize="14" FontWeight="Bold" Background="#FF2196F3" Foreground="White" 
                        Click="b_masterChange_Click" Margin="0,5,0,10"/>
            </StackPanel>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="3" Grid.Column="0" Background="#FFE3F2FD" Height="25">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="statusText" Text="Готово." FontSize="12" Margin="10,0,0,0"/>
                    <TextBlock x:Name="masterCountText" Text=" Мастеров: 0" FontSize="12" Margin="10,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Кнопка возврата -->
        <Button x:Name="b_masterReturn" Content="Вернуться" Grid.Row="3" Grid.Column="1"
                Height="35" Width="120" FontSize="14" FontWeight="Bold" 
                Background="#FF78909C" Foreground="White" Click="b_masterReturn_Click"
                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5" Cursor="Hand"/>
    </Grid>
</Window>