<Window x:Class="WpfApp_Krasotka.Appointments"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_Krasotka"
        mc:Ignorable="d"
        Title="Управление записями на услуги" Height="610" Width="1430">

    <Grid Background="#FFF0F8FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <Label x:Name="l_tabA" Content="Записи на услуги" Grid.Row="0" Grid.ColumnSpan="2"
       HorizontalAlignment="Center" VerticalAlignment="Center" 
       Height="45" FontSize="24" FontWeight="Bold" 
       Background="#FF1976D2" Foreground="White" Padding="20,5" 
       Width="250" Margin="75,10,397,10"/>

        <!-- Левая панель: кнопки управления и поиск -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="10,5,10,10">

            <!-- Панель кнопок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="b_appointmentShowActive" Content="Показать активные" Height="35" Width="185" 
                        FontSize="12" FontWeight="Bold" Click="b_appointmentShowActive_Click" 
                        Background="#FF2196F3" Foreground="White" Margin="0,0,5,0"/>
                <Button x:Name="b_appointmentShowInactive" Content="Показать неактивные" Height="35" Width="180" 
                        FontSize="12" FontWeight="Bold" Click="b_appointmentShowInactive_Click" 
                        Background="#FF78909C" Foreground="White" Margin="5,0"/>
                <Button x:Name="b_appointmentDelete" Content="Удалить" Height="35" Width="140" 
                        FontSize="12" FontWeight="Bold" Background="#5695f6" 
                        Foreground="White" Click="b_appointmentDelete_Click" Margin="5,0"/>
                <Button x:Name="b_appointmentAdd" Content="Добавить запись" Height="35" Width="157" 
                        FontSize="12" FontWeight="Bold" Background="#5695f6" 
                        Foreground="White" Click="b_appointmentAdd_Click" Margin="5,0"/>
                <Button x:Name="b_appointmentFilter" Content="Фильтр по дате" Height="35" Width="150" 
                        FontSize="12" FontWeight="Bold" Background="#5695f6" 
                        Foreground="White" Click="b_appointmentFilter_Click" Margin="5,0"/>
                <Button x:Name="b_appointmentExport" Content="Экспорт" Height="35" Width="129" 
                        FontSize="12" FontWeight="Bold" Background="#3F51D5" 
                        Foreground="White" Click="b_appointmentExport_Click" Margin="5,0"/>
            </StackPanel>

            <!-- Панель поиска -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Поиск записей:" VerticalAlignment="Center" Margin="0,0,10,0" 
                          FontSize="14" FontWeight="SemiBold"/>
                <TextBox x:Name="searchTextBox" Width="881" Height="30" Padding="5" 
                        TextChanged="searchTextBox_TextChanged" FontSize="14"
                        VerticalContentAlignment="Center" Background="White"
                        BorderBrush="#FF90CAF9" BorderThickness="1" RenderTransformOrigin="0.5,0.5">
                    <TextBox.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-0.006"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBox.RenderTransform>
                </TextBox>
            </StackPanel>
        </StackPanel>

        <!-- Таблица записей -->
        <DataGrid x:Name="appointmentCell" Grid.Row="2" Grid.Column="0"
          ItemsSource="{Binding AppointmentsClass}" ColumnWidth="*"
          Margin="10,0,10,0" 
          AutoGenerateColumns="False" SelectionMode="Single"
          SelectionChanged="appointmentCell_SelectionChanged"
          IsReadOnly="True"
          HorizontalScrollBarVisibility="Disabled">

            <!-- Полный стиль для синего выделения -->
            <DataGrid.Resources>
                <!-- Синий цвет выделения -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF2196F3"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFBBDEFB"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

                <!-- Стиль для строк -->
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#FF1976D2"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFE3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для ячеек -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#FF1976D2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Код записи" Binding="{Binding AppCode}" Width="75"/>
                <DataGridTextColumn Header="Мастер" Binding="{Binding MasterName}" Width="110"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="110"/>
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding ServTypeName}" Width="110"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding ServName}" Width="140"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding AppDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Время начала" Binding="{Binding QueueFrom}" Width="90"/>
                <DataGridTextColumn Header="Время окончания" Binding="{Binding QueueTo}" Width="110"/>
                <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="85"/>
                <DataGridTextColumn Header="Активный" Binding="{Binding AppointmentActivity}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель информации о записи -->
        <Border Grid.RowSpan="3" Grid.Column="1" 
                Background="#FFE3F2FD" Margin="10,10,10,5" 
                BorderBrush="#FF1976D2" BorderThickness="2" 
                CornerRadius="10" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="500" Padding="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Информация о записи" FontSize="16" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#FF1976D2"/>

                    <TextBlock Text="Код записи:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <TextBox x:Name="l_ac" FontSize="14" Height="30" Margin="0,0,0,10" 
                            Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                    <TextBlock Text="Мастер:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cb_master" FontSize="14" Height="30" Margin="0,0,0,10" 
                             Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"
                             DisplayMemberPath="MasterName"/>

                    <TextBlock Text="Клиент:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cb_client" FontSize="14" Height="30" Margin="0,0,0,10" 
                             Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"
                             DisplayMemberPath="ClientName"/>

                    <TextBlock Text="Тип услуги:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cb_servType" FontSize="14" Height="30" Margin="0,0,0,10" 
                             Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"
                             DisplayMemberPath="ServType"/>

                    <TextBlock Text="Услуга:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cb_service" FontSize="14" Height="30" Margin="0,0,0,10" 
                             Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"
                             DisplayMemberPath="ServName"/>

                    <TextBlock Text="Дата записи:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <DatePicker x:Name="dp_appDate" FontSize="14" Height="30" Margin="0,0,0,10" 
                               Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False"/>

                    <TextBlock Text="Время начала (час):" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <TextBox x:Name="l_qf" FontSize="14" Height="30" Margin="0,0,0,10" 
                            Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                    <TextBlock Text="Время окончания (час):" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <TextBox x:Name="l_qt" FontSize="14" Height="30" Margin="0,0,0,10" 
                            Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsReadOnly="True"/>

                    <TextBlock Text="Активный:" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cb_activity" FontSize="14" Height="30" Margin="0,0,0,20" 
                             Background="White" Padding="5" BorderBrush="#FF90CAF9" BorderThickness="1" IsEnabled="False">
                        <ComboBoxItem Content="Да" IsSelected="True"/>
                        <ComboBoxItem Content="Нет"/>
                    </ComboBox>

                    <Button x:Name="b_appointmentChange" Content="✏️ Изменить данные записи" Height="40" 
                            FontSize="14" FontWeight="Bold" Background="#FF2196F3" Foreground="White" 
                            Click="b_appointmentChange_Click" Margin="0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="3" Grid.Column="0" Background="#FFE3F2FD" Height="25">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="statusText" Text="Готово." FontSize="12" Margin="10,0,0,0"/>
                    <TextBlock x:Name="appointmentCountText" Text=" Записей: 0" FontSize="12" Margin="10,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Кнопка возврата -->
        <Button x:Name="b_appointmentReturn" Content="Вернуться" Grid.Row="3" Grid.Column="1"
                Height="35" Width="120" FontSize="14" FontWeight="Bold" 
                Background="#FF78909C" Foreground="White" Click="b_appointmentReturn_Click"
                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5" Cursor="Hand"/>
    </Grid>
</Window>